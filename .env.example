# new-api dashboard/API address.
NEWAPI_BASE_URL=http://localhost:3000

# Admin authentication for new-api management APIs.
# Use either NEWAPI_COOKIE or username/password login.
# In Docker, username/password is usually easier. If Turnstile/2FA blocks login,
# copy a dashboard Cookie into NEWAPI_COOKIE instead.
NEWAPI_COOKIE=
NEWAPI_USERNAME=
NEWAPI_PASSWORD=
NEWAPI_AUTHORIZATION=
NEWAPI_USER_HEADER=
NEWAPI_EXTRA_HEADERS_JSON={}
NEWAPI_REQUEST_TIMEOUT_MS=20000

# Collection window and page sizes.
NEWAPI_CHANNEL_PAGE_SIZE=100
NEWAPI_LOG_PAGE_SIZE=100
NEWAPI_LOG_HOURS=1
BALANCE_WARNING_USD=5

# OpenAI-compatible LLM endpoint. This can point back to your new-api /v1 endpoint.
LLM_BASE_URL=http://localhost:3000/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2

# Discord reporting.
DISCORD_WEBHOOK_URL=

# Scheduler/report behavior.
REPORT_INTERVAL_MINUTES=15
REPORT_MIN_REQUESTS=20
REPORT_FAILURE_RATE_THRESHOLD=0.3
REPORT_TIMEZONE=Asia/Hong_Kong
REPORT_SAVE_DIR=reports
REPORT_INCLUDE_RAW_SUMMARY=false

# Keep false for now. First version is report-only.
AUTO_EXECUTE=false

# Built-in management panel.
# Set PANEL_PASSWORD before exposing it through a host port or Cloudflare Tunnel.
PANEL_ENABLED=true
PANEL_HOST=0.0.0.0
PANEL_PORT=8787
PANEL_USERNAME=admin
PANEL_PASSWORD=
