{
  "name": "new-api-ai-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sidecar AI operations assistant for new-api.",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n panel,web -c cyan,green \"bun run src/index.ts dev\" \"bun run web:dev\"",
    "once": "bun run src/index.ts once",
    "start": "bun run src/index.ts start",
    "panel": "bun run src/index.ts panel",
    "dry-run": "bun run src/index.ts once --dry-run",
    "build": "bun run typecheck && bun run web:build",
    "web:dev": "vite --config web/vite.config.js",
    "web:build": "vite build --config web/vite.config.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^10.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.38"
  }
}
